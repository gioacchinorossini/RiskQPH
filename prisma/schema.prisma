generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  middleName   String?
  birthdate    DateTime?
  gender       String?
  barangay     String?
  address      String?
  latitude     Float?
  longitude    Float?
  /// verified | pending | rejected — pending until barangay head confirms self-registered residents
  barangayMemberStatus String @default("verified")
  email        String    @unique
  passwordHash String
  role         String    @default("resident") // default to resident
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reports      Report[]
  familyMembers FamilyMember[] @relation("FamilyHead")
  linkedAsFamily FamilyMember[] @relation("FamilyLink")
  safetyStatus   UserSafety[]
  familyRequestsSent    FamilyRequest[] @relation("RequestApplicant")
  familyRequestsReceived FamilyRequest[] @relation("RequestHead")
  evacueesRegistered    Evacuee[] @relation("EvacueeAddedBy")
}

model Disaster {
  id          String   @id @default(cuid())
  barangay    String
  isActive    Boolean  @default(true)
  type        String?  
  description String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  safetyReports UserSafety[]
}

model UserSafety {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  disasterId String
  disaster   Disaster @relation(fields: [disasterId], references: [id])
  isSafe     Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([disasterId])
  @@unique([userId, disasterId])
}

model FamilyMember {
  id           String    @id @default(cuid())
  userId       String?   // Linked registered user ID
  linkedUser   User?     @relation("FamilyLink", fields: [userId], references: [id])
  headId       String    // The primary user ID who added this member
  head         User      @relation("FamilyHead", fields: [headId], references: [id])
  firstName    String
  lastName     String
  middleName   String?
  relationship String
  birthdate    DateTime?
  gender       String?
  medicalNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([headId])
  @@index([userId])
}

model BarangayProfile {
  id        String   @id @default(cuid())
  name      String   @unique // The name of the barangay
  hqLatitude  Float?
  hqLongitude Float?
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  type        String
  description String?
  latitude    Float
  longitude   Float
  imageUrl    String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  isResolved  Boolean  @default(false)
  isFalseInfo Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model FamilyRequest {
  id          String   @id @default(cuid())
  headId      String
  head        User     @relation("RequestHead", fields: [headId], references: [id])
  applicantId String
  applicant   User     @relation("RequestApplicant", fields: [applicantId], references: [id])
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([headId, applicantId])
  @@index([headId])
  @@index([applicantId])
}

model EvacuationCenter {
  id        String   @id @default(cuid())
  name      String
  barangay  String
  latitude  Float
  longitude Float
  capacity  Int?
  type      String?
  evacuees  Evacuee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barangay])
}

model Evacuee {
  id                 String           @id @default(cuid())
  evacuationCenterId String
  evacuationCenter   EvacuationCenter @relation(fields: [evacuationCenterId], references: [id])
  firstName          String
  lastName           String
  middleName         String?
  gender            String?
  age               Int?
  medicalNotes      String?
  addedById         String
  addedBy           User             @relation("EvacueeAddedBy", fields: [addedById], references: [id])
  /// When set, evacuee was registered from a resident app QR (user id); one row per center per user
  registeredUserId  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([evacuationCenterId])
  @@index([addedById])
  @@index([registeredUserId])
}
