generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  middleName   String?
  birthdate    DateTime?
  gender       String?
  barangay     String?
  address      String?
  latitude     Float?
  longitude    Float?
  email        String    @unique
  passwordHash String
  role         String    @default("resident") // default to resident
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reports      Report[]
  familyMembers FamilyMember[] @relation("FamilyHead")
  linkedAsFamily FamilyMember[] @relation("FamilyLink")
}

model FamilyMember {
  id           String    @id @default(cuid())
  userId       String?   // Linked registered user ID
  linkedUser   User?     @relation("FamilyLink", fields: [userId], references: [id])
  headId       String    // The primary user ID who added this member
  head         User      @relation("FamilyHead", fields: [headId], references: [id])
  firstName    String
  lastName     String
  middleName   String?
  relationship String
  birthdate    DateTime?
  gender       String?
  medicalNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([headId])
  @@index([userId])
}

model Report {
  id          String   @id @default(cuid())
  type        String
  description String?
  latitude    Float
  longitude   Float
  imageUrl    String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  isResolved  Boolean  @default(false)
  isFalseInfo Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
