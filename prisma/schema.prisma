generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  middleName   String?
  birthdate    DateTime?
  gender       String?
  barangay     String?
  address      String?
  latitude     Float?
  longitude    Float?
  email        String    @unique
  passwordHash String
  role         String    @default("resident") // default to resident
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reports      Report[]
  familyMembers FamilyMember[] @relation("FamilyHead")
  linkedAsFamily FamilyMember[] @relation("FamilyLink")
  safetyStatus   UserSafety[]
}

model Disaster {
  id          String   @id @default(cuid())
  barangay    String
  isActive    Boolean  @default(true)
  type        String?  
  description String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  safetyReports UserSafety[]
}

model UserSafety {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  disasterId String
  disaster   Disaster @relation(fields: [disasterId], references: [id])
  isSafe     Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([disasterId])
  @@unique([userId, disasterId])
}

model FamilyMember {
  id           String    @id @default(cuid())
  userId       String?   // Linked registered user ID
  linkedUser   User?     @relation("FamilyLink", fields: [userId], references: [id])
  headId       String    // The primary user ID who added this member
  head         User      @relation("FamilyHead", fields: [headId], references: [id])
  firstName    String
  lastName     String
  middleName   String?
  relationship String
  birthdate    DateTime?
  gender       String?
  medicalNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([headId])
  @@index([userId])
}

model BarangayProfile {
  id        String   @id @default(cuid())
  name      String   @unique // The name of the barangay
  hqLatitude  Float?
  hqLongitude Float?
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  type        String
  description String?
  latitude    Float
  longitude   Float
  imageUrl    String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  isResolved  Boolean  @default(false)
  isFalseInfo Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
