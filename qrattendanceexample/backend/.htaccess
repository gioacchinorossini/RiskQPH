# Disable directory listing
<IfModule mod_autoindex.c>
  Options -Indexes
  IndexIgnore *
  # Descending security: no autoindex
</IfModule>

# Deny access to sensitive files
<FilesMatch "(?i)\.(sql|env|ini|log|sh|bat|ps1)$">
  Require all denied
</FilesMatch>

# Deny direct web access to backend configuration
<Files "config/database.php">
  Require all denied
</Files>

